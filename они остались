        { url: "https://t.me/proxy?server=wl.mtproto.online&port=443&secret=eedcaae509a2455bbfc6165f1708fd5c586d61782e7275&bot=@mtpro_xyz_bot&channel=@mtpro_xyz", note: "MTProto wl домен", type: "MTProto" },
        { url: "https://t.me/proxy?server=wl.mtproto.online&port=443&secret=dddcaae509a2455bbfc6165f1708fd5c58&bot=@mtpro_xyz_bot&channel=@mtpro_xyz", note: "MTProto short secret", type: "MTProto" },
        { url: "https://t.me/proxy?server=147.45.125.102&port=8443&secret=0ab9a7e5baf786ba3f5e9e054f83ec87", note: "MTProto", type: "MTProto" },
        { url: "https://t.me/proxy?server=150.241.68.154&port=443&secret=dd4d29f785a167560b74aa4ca9c63254c2", note: "MTProto EU", type: "MTProto" },
        { url: "https://t.me/proxy?server=185.107.74.128&port=10443&secret=ddb0c0d0def4ca6577bbb8fc7fd0b894", note: "MTProto high port", type: "MTProto" }
    ];

    // Функция для укорачивания отображения секретов/длинных ссылок, но полный url сохраняем
    function formatUrlForDisplay(fullUrl) {
        if (fullUrl.length > 68) {
            let prefix = fullUrl.substring(0, 64);
            return prefix + '…';
        }
        return fullUrl;
    }

    // функция копирования текста с уведомлением
    async function copyToClipboard(text, buttonElement) {
        try {
            await navigator.clipboard.writeText(text);
            const originalInner = buttonElement.innerHTML;
            buttonElement.innerHTML = '✅ Скопировано!';
            setTimeout(() => {
                buttonElement.innerHTML = originalInner;
            }, 1800);
        } catch (err) {
            console.error('Ошибка копирования:', err);
            buttonElement.innerHTML = '❌ Ошибка';
            setTimeout(() => {
                buttonElement.innerHTML = '📋 Копировать ссылку';
            }, 1200);
        }
    }

    // рендерим карточки
    function renderProxyList() {
        const container = document.getElementById('proxyListContainer');
        if (!container) return;

        let html = '';
        for (let item of proxyItems) {
            const displayUrl = item.url;
            const shortDisplay = formatUrlForDisplay(displayUrl);
            let iconEmoji = '🔗';
            if (item.type === 'MTProto') iconEmoji = '🚀';
            else if (item.type === 'SOCKS5') iconEmoji = '🧦';
            else if (item.type === 'GitHub') iconEmoji = '🐙';
            else if (item.type === 'Сервис') iconEmoji = '🌐';
            else iconEmoji = '📎';

            let extraTag = '';
            if (item.note && item.note.toLowerCase().includes('обходит')) {
                extraTag = '<span class="tag">🚫 обход белых списков</span>';
            } else if (item.type === 'SOCKS5') {
                extraTag = '<span class="tag">🧅 SOCKS5</span>';
            } else if (item.type === 'MTProto') {
                extraTag = '<span class="tag">✨ MTProto</span>';
            }

            const isTelegramLink = item.url.startsWith('https://t.me/');
            const copyText = item.url;

            html += `
                <div class="proxy-card">
                    <div class="card-link">
                        <div class="link-icon">${iconEmoji}</div>
                        <div class="link-info">
                            <div class="link-url" title="${escapeHtml(displayUrl)}">${escapeHtml(shortDisplay)}</div>
                            <div class="link-note">
                                <span>${escapeHtml(item.note)}</span>
                                ${extraTag}
                            </div>
                        </div>
                        <div style="display: flex; gap: 8px; align-items: center;">
                            <a href="${escapeHtml(item.url)}" target="_blank" rel="noopener noreferrer" class="copy-btn" style="text-decoration: none; background: #2a3a60; border: none; padding: 6px 18px;">🔓 Открыть</a>
                            <button class="copy-btn" data-clipboard="${escapeAttr(copyText)}">📋 Копировать ссылку</button>
                        </div>
                    </div>
                </div>
            `;
        }
        container.innerHTML = html;

        const allCopyButtons = document.querySelectorAll('.copy-btn[data-clipboard]');
        allCopyButtons.forEach(btn => {
            const urlToCopy = btn.getAttribute('data-clipboard');
            btn.addEventListener('click', (e) => {
                e.preventDefault();
                copyToClipboard(urlToCopy, btn);
            });
        });
    }

    function escapeHtml(str) {
        if (!str) return '';
        return str.replace(/[&<>]/g, function(m) {
            if (m === '&') return '&amp;';
            if (m === '<') return '&lt;';
            if (m === '>') return '&gt;';
            return m;
        }).replace(/[\uD800-\uDBFF][\uDC00-\uDFFF]/g, function(c) {
            return c;
        });
    }

    function escapeAttr(str) {
        if (!str) return '';
        return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    renderProxyList();

    // добавим мета-теги и дополнительное выделение для нового канала в футере/шапке
    const meta = document.createElement('meta');
    meta.name = "description";
    meta.content = "Список рабочих прокси для Telegram, обход белых списков, MTProto и SOCKS5. Канал @nekxdproxies — актуальные прокси каждый день!";
    document.head.appendChild(meta);
    
    // создадим элемент для дополнительного уведомления о новом канале (ненавязчиво)
    const extraNotify = document.createElement('div');
    extraNotify.style.marginTop = "1rem";
    extraNotify.style.marginBottom = "0.5rem";
    extraNotify.style.textAlign = "center";
    extraNotify.style.fontSize = "0.85rem";
    extraNotify.style.background = "rgba(255, 179, 71, 0.1)";
    extraNotify.style.padding = "8px 16px";
    extraNotify.style.borderRadius = "60px";
    extraNotify.style.width = "fit-content";
    extraNotify.style.marginLeft = "auto";
    extraNotify.style.marginRight = "auto";
    extraNotify.style.backdropFilter = "blur(8px)";
    extraNotify.innerHTML = '⭐️ НОВЫЙ ТЕЛЕГРАМ КАНАЛ С ПРОКСИ: <a href="https://t.me/nekxdproxies" target="_blank" style="color:#FFB347; font-weight:bold; text-decoration:underline;">@nekxdproxies</a> — ежедневные обновления!';
    const containerDiv = document.querySelector('.container');
    const alertCard = document.querySelector('.alert-card');
    if (containerDiv && alertCard) {
        alertCard.insertAdjacentElement('afterend', extraNotify);
    }
</script>
</body>
