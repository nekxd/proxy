<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Сохраните связь | Актуальные прокси Telegram</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(145deg, #0a0f1e 0%, #0c1222 100%);
            font-family: 'Segoe UI', 'Roboto', system-ui, -apple-system, 'Inter', 'Helvetica Neue', sans-serif;
            padding: 2rem 1.5rem;
            color: #eef2ff;
            min-height: 100vh;
        }

        /* контейнер с максимальной шириной */
        .container {
            max-width: 1100px;
            margin: 0 auto;
        }

        /* главный заголовок с анимацией */
        .warning-header {
            text-align: center;
            margin-bottom: 2.5rem;
            position: relative;
        }

        .neon-title {
            font-size: 3.2rem;
            font-weight: 800;
            letter-spacing: -0.02em;
            background: linear-gradient(135deg, #FFD166, #FF6B6B, #4ECDC4);
            background-size: 200% auto;
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            animation: shimmer 5s ease infinite;
            text-shadow: 0 2px 10px rgba(0,0,0,0.3);
            margin-bottom: 0.5rem;
        }

        @keyframes shimmer {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        .sub {
            font-size: 1rem;
            color: #9ca3cf;
            border-top: 1px solid rgba(78, 205, 196, 0.3);
            display: inline-block;
            padding-top: 0.7rem;
            margin-top: 0.5rem;
            backdrop-filter: blur(4px);
        }

        /* карточка-предупреждение */
        .alert-card {
            background: rgba(25, 30, 48, 0.85);
            backdrop-filter: blur(12px);
            border-radius: 2rem;
            padding: 1.4rem 2rem;
            margin-bottom: 2rem;
            border-left: 6px solid #ffb347;
            box-shadow: 0 20px 35px -12px rgba(0,0,0,0.5);
            transition: all 0.2s;
        }

        .alert-card p {
            font-size: 1.1rem;
            line-height: 1.4;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        .alert-icon {
            font-size: 2rem;
            filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));
        }

        .badge {
            background: #ff4d4d20;
            padding: 6px 12px;
            border-radius: 40px;
            font-size: 0.8rem;
            font-weight: 500;
            color: #ffb347;
            border: 1px solid #ffb34760;
        }

        /* сетка ссылок */
        .links-grid {
            display: flex;
            flex-direction: column;
            gap: 1rem;
            margin-bottom: 2.2rem;
        }

        .proxy-card {
            background: rgba(16, 20, 35, 0.7);
            backdrop-filter: blur(4px);
            border-radius: 1.5rem;
            transition: all 0.25s cubic-bezier(0.2, 0.9, 0.4, 1.1);
            border: 1px solid rgba(78, 205, 196, 0.2);
            overflow: hidden;
        }

        .proxy-card:hover {
            background: rgba(28, 34, 58, 0.9);
            border-color: #4ECDC4;
            transform: translateY(-2px);
            box-shadow: 0 12px 28px -8px rgba(0,0,0,0.5);
        }

        .card-link {
            display: flex;
            align-items: center;
            padding: 1rem 1.5rem;
            text-decoration: none;
            color: #eef2ff;
            gap: 14px;
            flex-wrap: wrap;
            justify-content: space-between;
        }

        .link-icon {
            font-size: 1.7rem;
            min-width: 44px;
            text-align: center;
        }

        .link-info {
            flex: 3;
            min-width: 180px;
        }

        .link-url {
            font-family: 'SF Mono', 'Fira Code', monospace;
            font-size: 0.85rem;
            word-break: break-all;
            color: #b9c3f0;
            letter-spacing: -0.2px;
            background: #00000040;
            padding: 4px 8px;
            border-radius: 12px;
            display: inline-block;
            max-width: 100%;
        }

        .link-note {
            font-size: 0.7rem;
            color: #8f9bb5;
            margin-top: 6px;
            display: flex;
            align-items: center;
            gap: 6px;
            flex-wrap: wrap;
        }

        .tag {
            background: #1f2a48;
            border-radius: 20px;
            padding: 2px 10px;
            font-size: 0.7rem;
            font-weight: 500;
            color: #a5f0e6;
        }

        .copy-btn {
            background: rgba(78, 205, 196, 0.12);
            border: 1px solid rgba(78, 205, 196, 0.5);
            border-radius: 40px;
            padding: 6px 16px;
            font-size: 0.75rem;
            font-weight: 600;
            color: #c0f5ef;
            cursor: pointer;
            transition: 0.15s;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            backdrop-filter: blur(4px);
        }

        .copy-btn:hover {
            background: #4ECDC4;
            color: #0a0f1e;
            border-color: #4ECDC4;
        }

        .copy-feedback {
            font-size: 0.7rem;
            margin-left: 8px;
            color: #6ee7b7;
        }

        /* дополнительные ресурсы */
        .extra-section {
            margin-top: 2rem;
            background: rgba(0, 0, 0, 0.3);
            border-radius: 1.8rem;
            padding: 1.4rem 1.8rem;
            border: 1px solid #2d374b;
        }

        .extra-title {
            font-size: 1.2rem;
            font-weight: 700;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .channels {
            display: flex;
            flex-wrap: wrap;
            gap: 1rem;
            align-items: center;
            justify-content: flex-start;
        }

        .channel-link {
            background: #1e293b;
            padding: 8px 20px;
            border-radius: 60px;
            text-decoration: none;
            color: #cbd5ff;
            font-weight: 500;
            transition: 0.2s;
            font-size: 0.9rem;
            border: 1px solid #334155;
        }

        .channel-link:hover {
            background: #2d3a5e;
            color: white;
            border-color: #4ECDC4;
        }

        hr {
            margin: 20px 0;
            border-color: #2a334e;
        }

        footer {
            text-align: center;
            margin-top: 3rem;
            font-size: 0.75rem;
            color: #5e6a8f;
        }

        @media (max-width: 680px) {
            body {
                padding: 1.2rem;
            }
            .neon-title {
                font-size: 2.2rem;
            }
            .card-link {
                flex-direction: column;
                align-items: flex-start;
            }
            .copy-btn {
                align-self: flex-end;
                margin-top: 6px;
            }
            .link-url {
                font-size: 0.75rem;
            }
        }

        .glow-text {
            font-weight: 600;
        }
        button {
            background: none;
            border: none;
            font-family: inherit;
        }
        .new-channel-highlight {
            background: linear-gradient(95deg, #2a2f4e, #1e2a3a);
            border: 1px solid #ffb347;
            box-shadow: 0 0 6px rgba(255, 180, 71, 0.3);
        }
    </style>
</head>
<body>
