        { url: "https://t.me/proxy?server=proxydlyavseh.sbs&port=443&secret=2cf24dba5fb0a30e26e83b2ac5b9e29e", note: "MTProto прокси", type: "MTProto" },
        { url: "https://t.me/proxy?server=43.250.53.22&port=443&secret=4fc30d1222972a04067e805a5134cb57", note: "MTProto IP", type: "MTProto" },
        { url: "https://t.me/proxy?server=65.109.215.115&port=8443&secret=dd104462821249bd7ac519130220c25d09", note: "MTProto 8443 порт", type: "MTProto" },
        { url: "https://t.me/socks?server=87.239.105.216&port=23785&user=FurkVPNbot&pass=FurkVPN&bot=@mtpro_xyz_bot&channel=@mtpro_xyz", note: "SOCKS5 от FurkVPN", type: "SOCKS5" },
